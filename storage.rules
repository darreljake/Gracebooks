rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function testingAccessOpen() {
      return request.time < timestamp.date(2027, 1, 1);
    }

    function signedIn() {
      return request.auth != null && testingAccessOpen();
    }

    function role() {
      return firestore.get(/databases/(default)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function hasRole(roles) {
      return signedIn() && role() in roles;
    }

    function validReceiptFile() {
      return request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    function validSignatureFile() {
      return request.resource.size <= 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /expense-receipts/{expenseId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if hasRole(['Treasurer']) && validReceiptFile();
      allow delete: if hasRole(['Treasurer']);
    }

    match /project-proofs/{entryId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if hasRole(['Treasurer']) && validReceiptFile();
      allow delete: if hasRole(['Treasurer']);
    }

    match /signatures/{uid}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid && validSignatureFile();
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    function isLiquidationRequestOwner(requestId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/liquidationRequests/$(requestId)).data.requesterUid == request.auth.uid;
    }

    match /liquidation-receipts/{requestId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if (hasRole(['Treasurer']) || isLiquidationRequestOwner(requestId)) && validReceiptFile();
      allow delete: if hasRole(['Treasurer']) || isLiquidationRequestOwner(requestId);
    }
  }
}
