rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function testingAccessOpen() {
      return request.time < timestamp.date(2027, 1, 1);
    }

    function signedIn() {
      return request.auth != null && testingAccessOpen();
    }

    function isTreasurer() {
      return signedIn() && request.auth.uid == 'CrJfm5bwpEhH3DCaKXgMntD0LHI3';
    }

    function validReceiptFile() {
      return request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    function validSignatureFile() {
      return request.resource.size <= 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /expense-receipts/{expenseId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isTreasurer() && validReceiptFile();
      allow delete: if isTreasurer();
    }

    match /project-proofs/{entryId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isTreasurer() && validReceiptFile();
      allow delete: if isTreasurer();
    }

    match /signatures/{uid}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid && validSignatureFile();
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    // Ownership is verified from the storage path itself (uid segment),
    // not a firestore.get() lookup - the same firestore.get() pattern in
    // this liquidation-receipts rule previously caused every non-Treasurer
    // upload here to fail with storage/unauthorized.
    match /liquidation-receipts/{requestId}/{uid}/{fileName} {
      allow read: if signedIn();
      allow create, update: if (isTreasurer() || (signedIn() && request.auth.uid == uid)) && validReceiptFile();
      allow delete: if isTreasurer() || (signedIn() && request.auth.uid == uid);
    }
  }
}
