rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function testingAccessOpen() {
      return request.time < timestamp.date(2027, 1, 1);
    }

    function signedIn() {
      return request.auth != null && testingAccessOpen();
    }

    function role() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }

    function hasRole(roles) {
      return signedIn() && role() in roles;
    }

    function notMembershipSecretary() {
      return signedIn() && role() != 'Membership Secretary';
    }

    function isPayrollOwner() {
      return signedIn()
        && resource.data.isPayrollGenerated == true
        && (
          (role() == 'Pastor' && resource.data.role == 'Pastor') ||
          (role() == 'Deaconess' && resource.data.role == 'Deaconess') ||
          (role() == 'Admin Assistant' && resource.data.role in ['Admin', 'Admin Assistant'])
        );
    }

    function isLiquidationOwner() {
      return signedIn() && resource.data.requesterUid == request.auth.uid;
    }

    match /userProfiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || role() == 'Treasurer');
      allow write: if false;
    }

    match /userSignatures/{uid} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /income/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create: if hasRole(['Treasurer', 'Money Counter']);
      allow update, delete: if hasRole(['Treasurer']);
    }

    match /expenses/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']) || isPayrollOwner();
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /members/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson', 'Money Counter', 'Membership Secretary']);
      allow create: if hasRole(['Treasurer', 'Money Counter', 'Membership Secretary']);
      allow update, delete: if hasRole(['Treasurer', 'Membership Secretary']);
    }

    match /attendance/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if hasRole(['Treasurer', 'Membership Secretary']);
    }

    match /churchObligations/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /reportReviews/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create: if hasRole(['Treasurer']);
      allow update: if hasRole(['Treasurer', 'Auditor', 'Finance Chair', 'Chairperson', 'Pastor']);
      allow delete: if hasRole(['Treasurer']);
    }

    match /notifications/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /liquidationRequests/{docId} {
      allow read: if hasRole(['Treasurer', 'Auditor']) || isLiquidationOwner();
      allow create: if (hasRole(['Pastor', 'Deaconess', 'Admin Assistant'])
          && request.resource.data.requesterUid == request.auth.uid)
        || hasRole(['Treasurer']);
      allow update: if hasRole(['Treasurer'])
        || (isLiquidationOwner()
          && request.resource.data.requesterUid == resource.data.requesterUid
          && (
            // Edit or cancel own request while it is still awaiting review.
            (resource.data.status == 'Submitted'
              && request.resource.data.status in ['Submitted', 'Cancelled'])
            // Submit liquidation for a released cash advance; the released
            // amount and request type cannot be altered by the requester.
            || (resource.data.status == 'Released'
              && request.resource.data.status == 'Liquidation Submitted'
              && request.resource.data.amount == resource.data.amount
              && request.resource.data.type == resource.data.type)
          ));
      allow delete: if hasRole(['Treasurer']);
    }

    match /specialProjects/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /specialProjectEntries/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /specialProjectCosts/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /auditLogs/{docId} {
      allow read: if hasRole(['Treasurer', 'Auditor']);
      allow create: if signedIn();
      allow update, delete: if hasRole(['Treasurer']);
    }

    match /budgets/{docId} {
      allow read: if notMembershipSecretary();
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /settings/{docId} {
      allow read: if notMembershipSecretary();
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /certificates/{docId} {
      // Certificate IDs are unguessable Firestore auto-IDs; a single-document
      // get lets the public verify page confirm authenticity without exposing
      // the collection to enumeration (list stays role-gated).
      allow get: if true;
      allow list: if hasRole(['Treasurer', 'Pastor']);
      allow create: if hasRole(['Treasurer']);
      allow update: if hasRole(['Treasurer', 'Pastor']);
      allow delete: if hasRole(['Treasurer']);
    }

    match /equipment/{docId} {
      allow read: if hasRole(['Treasurer', 'Pastor', 'Deaconess', 'Auditor', 'District', 'Finance Chair', 'Chairperson']);
      allow create, update, delete: if hasRole(['Treasurer']);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
